APP_NAME=KAPS AI Credit Intelligence API
APP_DESCRIPTION=Production-grade merchant search and credit intelligence platform
ENVIRONMENT=development
API_VERSION=1.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_TIMEOUT_SECONDS=30
WEBHOOK_SECRET=kaps-demo-secret-key

MYSQL_ROOT_PASSWORD=kaps-root-password
MYSQL_USER=kaps
MYSQL_PASSWORD=kaps-password
MYSQL_DATABASE=kaps_credit
DATABASE_URL=mysql+mysqlconnector://kaps:kaps-password@kaps-mysql:3306/kaps_credit
REDIS_URL=redis://kaps-redis:6379/0

AUTO_SEED_MERCHANTS=true
SEED_MERCHANT_COUNT=600
SEARCH_CACHE_TTL_SECONDS=300
AUTOCOMPLETE_CACHE_TTL_SECONDS=300
INDUSTRIES_CACHE_TTL_SECONDS=300
JOB_STATUS_TTL_SECONDS=300
RATE_LIMIT_PER_MINUTE=100
LOG_LEVEL=INFO

VITE_API_BASE_URL=http://localhost:8000
